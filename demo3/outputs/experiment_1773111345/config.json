{
  "seed": 42,
  "device": "auto",
  "data": {
    "dataset": "CIFAR10",
    "root": "./data",
    "image_size": 32,
    "batch_size": 128,
    "num_workers": 4
  },
  "model": {
    "latent_dim": 100,
    "ngf": 64,
    "ndf": 64,
    "num_classes": 10,
    "spectral_norm": true,
    "attn_heads": {
      "g": [
        8,
        4
      ],
      "d": [
        8
      ]
    }
  },
  "pretrain": {
    "lr_g": "2e-4",
    "lr_d": "2e-4",
    "betas": [
      0.5,
      0.999
    ],
    "epochs": 100,
    "d_steps": 3,
    "gp_lambda": 10.0,
    "class_lambda": 0.1,
    "loss_type": "wgan-gp"
  },
  "ppo": {
    "enabled": true,
    "actor_lr": "1e-4",
    "critic_lr": "3e-4",
    "gamma": 0.99,
    "lambda_gae": 0.95,
    "clip": 0.2,
    "ent_coef": 0.01,
    "n_steps": 1024,
    "update_epochs": 4,
    "batch_size": 64,
    "sigma": 0.1,
    "n_updates": 200
  },
  "rewards": {
    "w_adv": 1.0,
    "w_class": 0.1,
    "w_ssim": 0.5,
    "w_entropy": 0.01
  },
  "metrics": {
    "eval_num_images": 5000,
    "fid_batch_size": 50,
    "inception_batch_size": 50
  },
  "logging": {
    "eval_interval": 1,
    "save_interval": 10,
    "save_dir": "./outputs",
    "log_dir": "./logs",
    "tensorboard": true
  }
}